{{- $pages := after 1 .Pages -}}
{{- $paginator := .Paginate $pages 12 -}}
{{- $items := slice -}}
{{- range $paginator.Pages -}}
  {{- $image := "" -}}
  {{- with .Resources.GetMatch .Params.alt_image -}}
    {{- $image = .Permalink -}}
  {{- end -}}
  {{- $items = $items | append (dict
    "url" .Permalink
    "image" $image
    "title" .Title
    "summary" (default .Summary .Params.description | plainify)
  ) -}}
{{- end -}}
{{- dict
  "page" $paginator.PageNumber
  "items" $items
  | jsonify
-}}
